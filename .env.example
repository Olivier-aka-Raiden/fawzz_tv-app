# Mapbox (client-side — prefixed with VITE_)
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# RealtimeIRL pull key (server-side — NEVER exposed to browser)
# Get this from https://rtirl.com/ — the streamer's phone push key
# Used by api/location.ts to proxy GPS reads without exposing the key to the client
PULL_KEY=your_rtirl_pull_key_here

# Twitch API (server-side — read by Vercel function, NEVER exposed to browser)
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Upstash Redis — for persisting SubaBike tracking data server-side
# Install the integration from Vercel Marketplace → Storage → Redis
# The integration auto-sets these env vars on Vercel:
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
